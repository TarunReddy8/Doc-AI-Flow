# === DocAI Environment Configuration ===

# API Keys (set at least one)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=AIzaSyDDHY0eXQl-R2IsPxDKecB7fpznszHKWnQ

# LLM Configuration
LLM_PROVIDER=gemini              # mock | openai | anthropic | gemini
LLM_MODEL=gemini-2.0-flash       # gpt-4o-mini | claude-sonnet-4-20250514 | gemini-2.0-flash
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# OCR Configuration
OCR_ENGINE=doctr              # doctr | tesseract
OCR_CONFIDENCE_THRESHOLD=0.7

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=docai_documents

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=docai-extraction

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
MAX_FILE_SIZE_MB=50

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
DRIFT_CHECK_INTERVAL_HOURS=6
ACCURACY_THRESHOLD=0.85

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/docai.db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
